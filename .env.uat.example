NODE_ENV=development
PORT=3000

# Database — points to Postgres running on the host machine
DATABASE_URL=postgresql://USER:PASSWORD@host.docker.internal:5432/augmont_voice_agents

# Auth
JWT_SECRET=your-jwt-secret-here

# Bolna AI
BOLNA_API_KEY=your-bolna-api-key
BOLNA_API_BASE_URL=https://api.bolna.ai

# OpenAI (for behavioral analysis)
OPENAI_API_KEY=your-openai-api-key

# Webhook — update with your actual EC2 IP/domain
WEBHOOK_URL=http://YOUR_EC2_IP:3100/api/webhooks/bolna
